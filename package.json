{
  "name": "api-observability-platform",
  "version": "1.0.0",
  "description": "A full-stack API testing and monitoring system with Express, Newman, Prometheus, Grafana, Docker, Jest, and k6.",
  "main": "api/src/server.js",
  "scripts": {
    "start": "node api/src/server.js",
    "dev": "nodemon api/src/server.js",
    "test": "jest --runInBand",
    "test:postman": "newman run postman/api-observability.postman_collection.json --environment postman/local.postman_environment.json --reporters cli,json --reporter-json-export metrics/newman/latest-run.json",
    "test:postman:metrics": "node tests/newman/runCollection.js",
    "test:api": "jest tests/jest/api.test.js --runInBand",
    "load:stress": "k6 run tests/k6/stress-test.js",
    "load:spike": "k6 run tests/k6/spike-test.js",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "lint": "eslint api tests/jest tests/newman --ext .js"
  },
  "keywords": [
    "api-testing",
    "observability",
    "prometheus",
    "grafana",
    "newman",
    "devops",
    "sre"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "morgan": "^1.10.0",
    "prom-client": "^15.1.3",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^30.3.0",
    "newman": "^6.2.1",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
