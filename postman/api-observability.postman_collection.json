{
  "info": {
    "_postman_id": "67a8ba73-f22c-4627-b4f7-74d162ac3412",
    "name": "API Observability Platform - Synthetic SLA Suite",
    "description": "Synthetic API monitoring collection for validating health, functionality, schemas, and response time SLA targets.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "System Health - GET /health",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const body = pm.response.json();",
              "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
              "pm.test('Response time under 300ms', () => pm.expect(pm.response.responseTime).to.be.below(300));",
              "pm.test('Health schema is valid', () => {",
              "  pm.expect(body).to.have.property('status', 'healthy');",
              "  pm.expect(body).to.have.property('service');",
              "  pm.expect(body).to.have.property('uptimeSeconds').that.is.a('number');",
              "  pm.expect(body.checks).to.have.property('metrics', 'pass');",
              "});",
              "pm.test('Content validation includes timestamp', () => pm.expect(body.timestamp).to.match(/^\\d{4}-\\d{2}-\\d{2}T/));"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        }
      }
    },
    {
      "name": "Users Directory - GET /users",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const body = pm.response.json();",
              "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
              "pm.test('Response time under 300ms', () => pm.expect(pm.response.responseTime).to.be.below(300));",
              "pm.test('Users response schema is valid', () => {",
              "  pm.expect(body).to.have.property('data').that.is.an('array');",
              "  pm.expect(body).to.have.property('count').that.equals(body.data.length);",
              "  pm.expect(body.data[0]).to.include.keys(['id', 'name', 'email', 'role', 'region', 'active']);",
              "});",
              "pm.test('Content validation includes SRE persona data', () => {",
              "  const roles = body.data.map((user) => user.role);",
              "  pm.expect(roles).to.include('sre');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/users",
          "host": ["{{baseUrl}}"],
          "path": ["users"]
        }
      }
    },
    {
      "name": "Knowledge Posts - GET /posts",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const body = pm.response.json();",
              "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
              "pm.test('Response time under 300ms', () => pm.expect(pm.response.responseTime).to.be.below(300));",
              "pm.test('Posts response schema is valid', () => {",
              "  pm.expect(body).to.have.property('data').that.is.an('array');",
              "  pm.expect(body.data[0]).to.include.keys(['id', 'title', 'body', 'authorId', 'tags', 'status', 'createdAt']);",
              "});",
              "pm.test('Content validation includes SLA terminology', () => {",
              "  const combined = body.data.map((post) => `${post.title} ${post.body}`).join(' ');",
              "  pm.expect(combined.toLowerCase()).to.include('sla');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/posts",
          "host": ["{{baseUrl}}"],
          "path": ["posts"]
        }
      }
    },
    {
      "name": "Publish Post - POST /posts",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const body = pm.response.json();",
              "pm.test('Status code is 201', () => pm.response.to.have.status(201));",
              "pm.test('Response time under 300ms', () => pm.expect(pm.response.responseTime).to.be.below(300));",
              "pm.test('Create post response schema is valid', () => {",
              "  pm.expect(body).to.have.property('data');",
              "  pm.expect(body.data).to.include.keys(['id', 'title', 'body', 'authorId', 'tags', 'status', 'createdAt']);",
              "  pm.expect(body.data.status).to.equal('published');",
              "});",
              "pm.test('Content validation confirms publishing API accepted request', () => {",
              "  pm.expect(body.message).to.include('accepted');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Synthetic monitoring release note\",\n  \"body\": \"This post validates the write path used by the API monitoring suite.\",\n  \"authorId\": 1,\n  \"tags\": [\"synthetic-monitoring\", \"sla\", \"release\"]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/posts",
          "host": ["{{baseUrl}}"],
          "path": ["posts"]
        }
      }
    }
  ]
}
